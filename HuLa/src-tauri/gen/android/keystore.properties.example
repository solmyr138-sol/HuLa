# Copy to keystore.properties (gitignored) and point storeFile at your .jks.
# Generate once: keytool -genkey -v -keystore upload-keystore.jks -keyalg RSA -keysize 2048 -validity 10000 -alias upload
password=YOUR_STORE_AND_KEY_PASSWORD
keyAlias=upload
# Windows: use forward slashes only — backslashes break Properties (\Users → \uXXXX)
storeFile=C:/Users/P1/upload-keystore.jks
